{
  "name": "obsidian-local-mcp",
  "version": "0.1.0",
  "description": "Local Obsidian Vault MCP server (create/read/write notes & folders with Obsidian YAML properties) + web settings UI + Claude skill",
  "type": "module",
  "bin": {
    "obsidian-local-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/ui','dist/ui',{recursive:true})\"",
    "start": "node dist/index.js",
    "settings": "node dist/settings-server.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
